# --- Connections (Railway will inject these from Postgres/Redis services) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/medusa
REDIS_URL=redis://default:password@localhost:6379?family=0

# --- Secrets (use Railway ${{secret(32)}} in production) ---
JWT_SECRET=replace-me
COOKIE_SECRET=replace-me

# --- CORS (point to your public Railway domain) ---
STORE_CORS=https://your-medusa.up.railway.app
ADMIN_CORS=https://your-medusa.up.railway.app
AUTH_CORS=https://your-medusa.up.railway.app

# --- Backend URL (for admin asset paths) ---
BACKEND_URL=https://your-medusa.up.railway.app

# --- Mode & port ---
MEDUSA_WORKER_MODE=shared
DISABLE_MEDUSA_ADMIN=false
PORT=9000
NODE_ENV=production

# --- Admin user (created on first boot, ignored thereafter) ---
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=change-me-on-first-login

PAYSTACK_SECRET_KEY=ps-
